# VeneMed environment.
#
# ----------------------------------------------------------------------------
# LOCAL DEV (recommended): run a fully-local Supabase via the CLI + Docker.
#   pnpm supabase:start && pnpm db:setup && pnpm dev      # or: pnpm dev:local
# Then .env.local should contain the LOCAL values below. The anon/service keys
# are the deterministic local demo keys — copy the exact values printed by
#   pnpm exec supabase status
# Local Supabase has NO pooler, so both POSTGRES URLs use the direct :54322 port.
# Center login/registration work offline via the [auth.email.test_otp] map in
# supabase/config.toml (TEST_OTP_CODE 123456).
#
# POSTGRES_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
# POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
# NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="<supabase status → anon key>"
# SUPABASE_SERVICE_ROLE_KEY="<supabase status → service_role key>"
# CRON_SECRET="local-dev-secret"
# TEST_CENTER_EMAIL="center@venemed.test"
# TEST_CENTER_EMAIL_2="center2@venemed.test"
# TEST_OTP_CODE="123456"
#
# To use PROD creds instead (read-only debugging), restore the backup or re-pull:
#   cp .env.vercel.local .env.local   # quick restore (prod stays authoritative on Vercel)
#   vercel env pull .env.local        # canonical re-pull
# ----------------------------------------------------------------------------
#
# PROD / CLOUD (authoritative on Vercel):
# These are provisioned by the Supabase integration on Vercel.
# For prod creds locally, run:  vercel env pull .env.local
#
# Postgres (Supabase via Vercel integration):
POSTGRES_URL="postgresql://...:6543/postgres"            # transaction pooler — app runtime
POSTGRES_URL_NON_POOLING="postgresql://...:5432/postgres" # direct — drizzle migrations
#
# Supabase project API (client + auth):
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."
#
# Cloudflare Turnstile (captcha on phone-OTP send — audit issue #22).
# PUBLIC site key (safe in the browser bundle). Pair the matching SECRET key into
# Supabase Auth → Attack Protection → CAPTCHA (Turnstile). When UNSET, the captcha
# widget renders nothing and OTP sends skip the token — keep it unset for local
# dev + CI (Supabase captcha disabled there); set it in Vercel for prod/preview.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAA..."
#
# Sentry error tracking (optional). PUBLIC DSN — when UNSET (local dev + CI),
# Sentry is fully disabled and nothing is sent. Set it in Vercel for prod/preview.
# Config is hardened: errors only (no perf tracing), no Session Replay, no PII/IP,
# and phone numbers are scrubbed before send (see src/lib/sentry/options.ts).
# NEXT_PUBLIC_SENTRY_DSN="https://<key>@<org>.ingest.sentry.io/<project>"
# Source-map upload at build time (CI/prod only) — leave unset locally:
# SENTRY_ORG="..."
# SENTRY_PROJECT="..."
# SENTRY_AUTH_TOKEN="..."
# Cron auth (see docs/specs/cron-jobs.md §4):
# Shared secret Vercel sends as `Authorization: Bearer $CRON_SECRET` to /api/cron/*.
# Set on Vercel for Production/Preview/Development; generate with `openssl rand -hex 32`.
CRON_SECRET="..."
#
# e2e smoke (see docs/specs/e2e-smoke.md):
# Supabase TEST emails for the gated center/admin specs. The e2e reads the real
# OTP code from the local Supabase mail sink (Mailpit); a LOCAL-ONLY email
# template surfaces the 6-digit code (see e2e/_mail.ts). center.spec skips
# cleanly while TEST_CENTER_EMAIL is empty.
TEST_CENTER_EMAIL="center@venemed.test"     # center.spec.ts (login)
TEST_CENTER_EMAIL_2="center2@venemed.test"  # center.spec.ts (registration)
# TEST_ADMIN_EMAIL: a THIRD, distinct test email for the gated admin moderation
# e2e (admin.spec.ts). Must differ from the two above — reusing them would flip a
# center-flow user to is_platform_admin.
TEST_ADMIN_EMAIL="admin@venemed.test"

# TEST_CENTER_EMAIL_3: a FOURTH, distinct test email — the INVITEE in
# center-team.spec.ts. TEST_CENTER_EMAIL_2 already gets a membership in
# center.spec.ts's registration test, which would trip the one-center-per-user
# unique index if reused here as the invitee.
TEST_CENTER_EMAIL_3="center3@venemed.test"

# Base URL used to build shareable team-invite links
# (`${NEXT_PUBLIC_SITE_URL}/centro/unirse/<token>`) instead of trusting request
# headers. Set on Vercel for prod/preview (prod: https://venemedapp.org).
NEXT_PUBLIC_SITE_URL="http://localhost:3140"

# ----------------------------------------------------------------------------
# Feature flags (NEXT_PUBLIC_, build-time; default OFF — only "true" enables).
# ----------------------------------------------------------------------------
# CENTER TYPE ("Tipo de centro"): registration field + donor "Sector" filter +
# admin display. Off by default; while off, center.type is stored NULL.
NEXT_PUBLIC_FEATURE_CENTER_TYPE="false"
