# VeneMed environment.
# These are provisioned by the Supabase integration on Vercel.
# For local dev, run:  vercel env pull .env.local
#
# Postgres (Supabase via Vercel integration):
POSTGRES_URL="postgresql://...:6543/postgres"            # transaction pooler — app runtime
POSTGRES_URL_NON_POOLING="postgresql://...:5432/postgres" # direct — drizzle migrations
#
# Supabase project API (client + auth):
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."
#
# Cron auth (see docs/specs/cron-jobs.md §4):
# Shared secret Vercel sends as `Authorization: Bearer $CRON_SECRET` to /api/cron/*.
# Set on Vercel for Production/Preview/Development; generate with `openssl rand -hex 32`.
CRON_SECRET="..."
#
# e2e smoke (see docs/specs/e2e-smoke.md):
# Supabase TEST phone (national digits, +58 implied) with a fixed OTP code,
# configured in Supabase Auth. Not secrets-in-repo — wired via env / GH secrets.
TEST_CENTER_PHONE="4241234567"   # national digits used by center.spec.ts
# TEST_OTP_CODE: 6 digits. Leave UNSET until the correct code is confirmed —
# center.spec.ts skips cleanly while this is empty.
TEST_CENTER_PHONE_2="4221234567"  # second test number for registration e2e (avoids OTP rate-limit)
TEST_OTP_CODE=""
