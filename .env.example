# VeneMed environment.
#
# ----------------------------------------------------------------------------
# LOCAL DEV (recommended): run a fully-local Supabase via the CLI + Docker.
#   pnpm supabase:start && pnpm db:setup && pnpm dev      # or: pnpm dev:local
# Then .env.local should contain the LOCAL values below. The anon/service keys
# are the deterministic local demo keys — copy the exact values printed by
#   pnpm exec supabase status
# Local Supabase has NO pooler, so both POSTGRES URLs use the direct :54322 port.
# Center login/registration work offline via the [auth.sms.test_otp] map in
# supabase/config.toml (TEST_OTP_CODE 123456).
#
# POSTGRES_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
# POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
# NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="<supabase status → anon key>"
# SUPABASE_SERVICE_ROLE_KEY="<supabase status → service_role key>"
# CRON_SECRET="local-dev-secret"
# TEST_CENTER_PHONE="4241234567"
# TEST_CENTER_PHONE_2="4221234567"
# TEST_OTP_CODE="123456"
#
# To use PROD creds instead (read-only debugging), restore the backup or re-pull:
#   cp .env.vercel.local .env.local   # quick restore (prod stays authoritative on Vercel)
#   vercel env pull .env.local        # canonical re-pull
# ----------------------------------------------------------------------------
#
# PROD / CLOUD (authoritative on Vercel):
# These are provisioned by the Supabase integration on Vercel.
# For prod creds locally, run:  vercel env pull .env.local
#
# Postgres (Supabase via Vercel integration):
POSTGRES_URL="postgresql://...:6543/postgres"            # transaction pooler — app runtime
POSTGRES_URL_NON_POOLING="postgresql://...:5432/postgres" # direct — drizzle migrations
#
# Supabase project API (client + auth):
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."
#
# Cron auth (see docs/specs/cron-jobs.md §4):
# Shared secret Vercel sends as `Authorization: Bearer $CRON_SECRET` to /api/cron/*.
# Set on Vercel for Production/Preview/Development; generate with `openssl rand -hex 32`.
CRON_SECRET="..."
#
# e2e smoke (see docs/specs/e2e-smoke.md):
# Supabase TEST phone (national digits, +58 implied) with a fixed OTP code,
# configured in Supabase Auth. Not secrets-in-repo — wired via env / GH secrets.
TEST_CENTER_PHONE="4241234567"   # national digits used by center.spec.ts
# TEST_OTP_CODE: 6 digits. Leave UNSET until the correct code is confirmed —
# center.spec.ts skips cleanly while this is empty.
TEST_CENTER_PHONE_2="4221234567"  # second test number for registration e2e (avoids OTP rate-limit)
# TEST_ADMIN_PHONE: a THIRD, distinct test number for the gated admin moderation
# e2e (admin.spec.ts). Must differ from the two above — reusing them would flip a
# center-flow user to is_platform_admin and collide on the ~1/min OTP limit. The
# admin spec skips cleanly until this (and TEST_OTP_CODE) are set.
TEST_ADMIN_PHONE="4261234567"
TEST_OTP_CODE=""

# ----------------------------------------------------------------------------
# Feature flags (NEXT_PUBLIC_, build-time; default OFF — only "true" enables).
# ----------------------------------------------------------------------------
# CENTER TYPE ("Tipo de centro"): registration field + donor "Sector" filter +
# admin display. Off by default; while off, center.type is stored NULL.
NEXT_PUBLIC_FEATURE_CENTER_TYPE="false"
